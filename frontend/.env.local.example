# Local Hardhat node — copy to .env.local and fill in contract addresses after running:
#   cd contracts && node scripts/e2e-local.js
#
# The script prints the deployed addresses and writes them here automatically.

VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545
VITE_TOKEN_ADDRESS=
VITE_DISPERSE_ADDRESS=
VITE_AIRDROP_ADDRESS=

# Set to "true" to skip ZamaProvider (no real FHE encrypt/decrypt, used in Playwright smoke tests)
VITE_SKIP_ZAMA=false
