{
  "name": "confidential-drop-contracts",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "e2e:local": "hardhat run scripts/e2e-local.js --network hardhat",
